<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>게시물 작성</title>
    <style>
        textarea {
            width: 300px;
            height: 30px;
            font-size: 18px;
            resize: none;
        }
    </style>
</head>
<body>
    <h1>게시물 작성</h1>
    <form action="/posts" method="post">
        <p>제목: <input type="text" name="title"></p>
        <p>
            내용: <br>
            <textarea name="content"></textarea>
        </p>
        <p><button type="submit">저장</button></p>
    </form>
</body>
</html>